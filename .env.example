# ─── Auth0 (client-side) ──────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id

# ─── Auth0 (server-side — API route JWT validation) ───────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# ─── Supabase (server-side — service role, never expose to browser) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── Meta / Instagram ─────────────────────────────────────────────────────────
META_VERIFY_TOKEN=your_webhook_verify_token
META_PAGE_ACCESS_TOKEN=your_page_access_token

# ─── Webhook base URL (used for Twilio signature validation) ──────────────────
BASE_URL=https://your-vercel-app.vercel.app

# ─── Admin access ─────────────────────────────────────────────────────────────
ADMIN_AUTH0_SUBS=auth0|abc123,auth0|def456
ADMIN_EMAILS=admin@example.com

# ─── Dev only ─────────────────────────────────────────────────────────────────
# ALLOW_LEGACY_BUSINESS_HEADER=true
# NEXT_PUBLIC_BUSINESS_ID=your_business_uuid_for_dev
