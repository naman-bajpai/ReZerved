# BookedUp Frontend — copy to .env.local (never commit .env.local)

NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth0 — Single Page Application (same Application as backend audience / identifier)
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_spa_client_id
# Must match the API Identifier you create in Auth0 → APIs (used by the backend AUTH0_AUDIENCE)
NEXT_PUBLIC_AUTH0_AUDIENCE=https://bookedup.api
# Add this exact URL to Auth0 → Application → Allowed Callback URLs and Allowed Logout URLs
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/dashboard

# Optional: legacy dashboard without login (requires backend ALLOW_LEGACY_BUSINESS_HEADER=true)
# NEXT_PUBLIC_BUSINESS_ID=uuid-from-supabase-businesses
